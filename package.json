{
  "name": "shokunin-light",
  "displayName": "Shokunin",
  "description": "Light and dark VS Code themes for Python-focused craft: sumi classes, ume type hints, asagi functions.",
  "version": "0.2.0",
  "publisher": "maksim-burtsev",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Maksim-Burtsev/shokunin-theme"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "vscode-theme",
    "light-theme",
    "dark-theme",
    "python",
    "rice-paper",
    "shokunin",
    "japanese",
    "sumi",
    "ume",
    "asagi"
  ],
  "engines": {
    "vscode": "^1.86.0"
  },
  "scripts": {
    "test": "node --test",
    "package": "vsce package",
    "package:check": "npm run package && node scripts/check-vsix-contents.mjs",
    "publish": "vsce publish",
    "publish:pre": "vsce publish --pre-release",
    "generate:iterm": "node scripts/generate-itermcolors.mjs"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2"
  },
  "contributes": {
    "themes": [
      {
        "label": "Shokunin Light",
        "uiTheme": "vs",
        "path": "./themes/shokunin-sumi-ume-color-theme.json"
      },
      {
        "label": "Shokunin Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/shokunin-yoru-sumi-color-theme.json"
      }
    ]
  }
}
