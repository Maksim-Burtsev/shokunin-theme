  "tokenColors": [
    {
      "name": "Comment — sumi quiet",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#88877E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings — tea green",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#83BE8D"
      }
    },
    {
      "name": "Numbers and constants — kintsugi amber",
      "scope": [
        "constant.numeric",
        "variable.other.constant",
        "support.constant",
        "constant.other",
        "constant.language.boolean",
        "constant.language.json",
        "constant.language.yaml"
      ],
      "settings": {
        "foreground": "#D3A34D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Python None — sumi keyword-like",
      "scope": [
        "constant.language.python"
      ],
      "settings": {
        "foreground": "#D7C4AA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keywords and control flow — warm sumi",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.word",
        "keyword.other",
        "storage.type.function.python",
        "storage.type.class.python",
        "storage.modifier.async.python",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D7C4AA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators and punctuation — neutral ink",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.section",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#A39C91"
      }
    },
    {
      "name": "Types and type hints — ume",
      "scope": [
        "support.type",
        "support.type.python",
        "support.class.builtin.python",
        "entity.name.type",
        "entity.other.inherited-class",
        "meta.function.typehint.python",
        "meta.type.annotation.python",
        "meta.annotation.python",
        "storage.type.annotation.python"
      ],
      "settings": {
        "foreground": "#D28AA0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes — warm ink highlight",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class",
        "meta.class.python entity.name.type.class",
        "meta.class.python entity.name.class"
      ],
      "settings": {
        "foreground": "#E0CEB4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions and methods — asagi blue",
      "scope": [
        "entity.name.function",
        "entity.name.function.member",
        "support.function",
        "support.function.builtin",
        "variable.function"
      ],
      "settings": {
        "foreground": "#6FB7D7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators — dry wood",
      "scope": [
        "entity.name.function.decorator",
        "meta.function.decorator.python",
        "punctuation.definition.decorator.python",
        "keyword.operator.decorator.python"
      ],
      "settings": {
        "foreground": "#D09161",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Properties and attributes — quiet structure",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.member.access",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#AFB8B8"
      }
    },
    {
      "name": "Parameters — main ink",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable.parameter"
      ],
      "settings": {
        "foreground": "#CFC2B0"
      }
    },
    {
      "name": "Markup headings — warm ink highlight",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#E0CEB4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup links — asagi",
      "scope": [
        "string.other.link",
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#6FB7D7"
      }
    },
    {
      "name": "Markup inline code — kintsugi",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#D3A34D"
      }
    },
    {
      "name": "Invalid — diagnostic red only",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#E06C75",
        "fontStyle": "bold"
      }
    }
  ],
